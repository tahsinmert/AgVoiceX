POSTGRES_DB=voice_agent
POSTGRES_USER=voice_agent
POSTGRES_PASSWORD=voice_agent
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333

DEFAULT_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CANDIDATE_URLS=http://host.docker.internal:11434,http://localhost:11434,http://ollama:11434
LMSTUDIO_BASE_URL=http://host.docker.internal:1234
OLLAMA_REQUEST_TIMEOUT_SECONDS=60

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:5678,http://localhost:3000

N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=localhost
N8N_HOST_PORT=5678
N8N_PORT=5678
N8N_PROTOCOL=http
